{
  "name": "anywhere-terminal",
  "displayName": "AnyWhere Terminal",
  "description": "Break free from the bottom panel! Put your terminal anywhere: Primary Sidebar, Secondary Sidebar, or multiple panels at once.",
  "version": "0.2.1",
  "publisher": "huybuidac",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/huybuidac/anywhere-terminal"
  },
  "bugs": {
    "url": "https://github.com/huybuidac/anywhere-terminal/issues"
  },
  "homepage": "https://github.com/huybuidac/anywhere-terminal#readme",
  "keywords": [
    "terminal",
    "sidebar",
    "panel",
    "anywhere",
    "xterm",
    "secondary sidebar"
  ],
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:anywhereTerminal.sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anywhereTerminal",
          "title": "AnyWhere Terminal",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "anywhereTerminal": [
        {
          "id": "anywhereTerminal.sidebar",
          "name": "AnyWhere Terminal",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "biome check --write --unsafe src/",
    "format": "biome format --write src/",
    "test": "vscode-test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "test:unit:coverage": "vitest run --coverage",
    "deploy": "vsce package --no-dependencies && vsce publish --no-dependencies && ovsx publish anywhere-terminal-*.vsix",
    "deploy:vsce": "vsce publish --no-dependencies",
    "deploy:ovsx": "vsce package --no-dependencies && ovsx publish anywhere-terminal-*.vsix",
    "deploy:patch": "vsce publish patch --no-dependencies && ovsx publish anywhere-terminal-*.vsix",
    "deploy:minor": "vsce publish minor --no-dependencies && ovsx publish anywhere-terminal-*.vsix",
    "cf": "bun run .agents/skills/cyberk-flow/scripts/cf.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@huggingface/transformers": "latest",
    "@opencode-ai/plugin": "latest",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
