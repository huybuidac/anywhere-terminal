{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@franlol/opencode-md-table-formatter@latest"],
  "permission": {
    "question": "allow"
  },
  "agent": {
    "cf-master": {
      "permission": {
        "read": "allow",
        "edit": "allow",
        "task": "allow",
        "question": "allow"
      }
    },
    "cf-librarian": {
      "permission": {
        "read": "allow",
        "edit": {
          "docs": "allow",
          "cyberk-flow": "allow"
        },
        "task": "allow"
      }
    },
    "cf-oracle": {
      "permission": {
        "read": "allow"
      },
      "reasoningEffort": "high"
    },
    "cf-review": {
      "permission": {
        "read": "allow"
      }
    },
    "cf-review-master": {
      "permission": {
        "read": "allow",
        "edit": "allow",
        "task": "allow",
        "question": "allow"
      },
      "reasoningEffort": "high"
    },
    "cf-review-contracts": {
      "permission": {
        "read": "allow"
      },
      "reasoningEffort": "high"
    },
    "cf-review-data-security": {
      "permission": {
        "read": "allow"
      },
      "reasoningEffort": "high"
    },
    "cf-review-frontend": {
      "permission": {
        "read": "allow"
      },
      "reasoningEffort": "high"
    },
    "cf-review-logic": {
      "permission": {
        "read": "allow"
      },
      "reasoningEffort": "high"
    },
    "cf-knowledge-extract": {
      "permission": {
        "read": "allow",
        "edit": "allow",
        "task": "allow",
        "question": "allow"
      }
    },
    "cf-build": {
      "permission": {
        "read": "allow",
        "edit": "allow",
        "task": "allow",
        "question": "allow"
      }
    },
    "cf-plan": {
      "permission": {
        "read": "allow",
        "edit": "allow",
        "task": "allow",
        "question": "allow"
      }
    },
    "cf-archive": {
      "permission": {
        "read": "allow",
        "edit": "allow",
        "task": "allow",
        "question": "allow"
      }
    }
  }
}
