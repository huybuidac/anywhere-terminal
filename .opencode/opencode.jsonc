{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@franlol/opencode-md-table-formatter@latest"],
  "permission": {
    "question": "allow"
  },
  "agent": {
    "cf-master": {
      "permission": {
        "edit": {
          "docs": "allow"
        },
        "task": "allow",
        "question": "allow"
      }
    },
    "cf-librarian": {
      "permission": {
        "edit": {
          "docs": "allow",
          "cyberk-flow": "allow"
        },
        "task": "allow"
      }
    },
    "cf-build": {
      "permission": {
        "edit": "allow",
        "task": "allow",
        "question": "allow"
      }
    },
    "cf-plan": {
      "permission": {
        "edit": {
          "docs": "allow",
          "cyberk-flow": "allow"
        },
        "task": "allow",
        "question": "allow"
      }
    },
    "cf-archive": {
      "permission": {
        "edit": {
          "docs": "allow",
          "cyberk-flow": "allow"
        },
        "task": "allow",
        "question": "allow"
      }
    }
  }
}
